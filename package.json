{
  "name": "miroo-nft-tools",
  "version": "2.0.12",
  "description": "Miroo NFT Tools — NFT Trait Generator & Collection Manager",
  "main": "main.js",
  "author": "Miroo",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.miroo.nft-tools",
    "productName": "Miroo NFT Tools",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "ipc-handlers.js",
      "lib/**/*",
      "dist/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "publisherName": "Miroo"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "shortcutName": "Miroo NFT Tools"
    },
    "extraResources": []
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.10.0",
    "form-data": "^4.0.6",
    "sharp": "^0.33.5"
  }
}
